<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.claude-speak.daemon</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/__USERNAME__/Projects/claude-speak/.venv/bin/python</string>
        <string>-m</string>
        <string>claude_speak_daemon</string>
        <string>start</string>
        <string>--foreground</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/__USERNAME__/Projects/claude-speak</string>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/tmp/claude-speak.log</string>

    <key>StandardErrorPath</key>
    <string>/tmp/claude-speak.log</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/Users/__USERNAME__/Projects/claude-speak/.venv/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
    </dict>
</dict>
</plist>
